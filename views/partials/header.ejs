<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Smart Event Management Platform</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <nav>
      <div class="logo">
        <a href="/">EventMaster</a>
      </div>
      <div class="nav-links">
        <a href="/">Home</a>
        
        <% if (typeof user !== 'undefined' && user) { %>
          <% if (user.role === 'admin') { %>
            <a href="/manage">Manage Events</a>
            <a href="/dashboard">Analytics</a>
            <a href="/contact">Enquiries</a>
          <% } else if (user.role === 'user') { %>
            <a href="/dashboard">My Bookings</a>
            <a href="/contact">Contact</a>
          <% } %>
          <a href="/logout">Logout (<%= user.name %>)</a>
        <% } else { %>
          <a href="/auth">Login/Register</a>
        <% } %>
      </div>
    </nav>
  </header>
  <main>